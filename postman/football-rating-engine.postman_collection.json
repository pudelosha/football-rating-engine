    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.apiKey) {",
                  "  pm.collectionVariables.set('apiKey', json.apiKey);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manual-test-{{$timestamp}}@example.com\",\n  \"password\": \"replace-with-local-user-password\",\n  \"displayName\": \"Manual Test User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Request Password Reset",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/request-password-reset",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "request-password-reset"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Squad Quality - Transfermarkt",
      "item": [
        {
          "name": "Import Transfermarkt Squad",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Import succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.snapshotId) {",
                  "  pm.collectionVariables.set('snapshotId', json.snapshotId);",
                  "}",
                  "if (json.teamId) {",
                  "  pm.collectionVariables.set('teamId', json.teamId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transfermarktUrl\": \"{{transfermarktUrl}}\",\n  \"season\": \"{{season}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/teams/{{teamId}}/transfermarkt/import",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "teams",
                "{{teamId}}",
                "transfermarkt",
                "import"
              ]
            }
          }
        },
